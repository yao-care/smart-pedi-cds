{
  "name": "cdss-pediatric",
  "type": "module",
  "version": "0.1.0",
  "description": "開源 Smart Pedi 兒童發展評估 — SMART on FHIR 瀏覽器端 CDS",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "astro dev",
    "predev": "tsx scripts/build-content-index.ts && tsx scripts/build-questionnaire-applicability.ts",
    "build": "astro build",
    "build:video-index": "tsx scripts/build-content-index.ts",
    "prebuild": "tsx scripts/build-content-index.ts && tsx scripts/build-questionnaire-applicability.ts",
    "preview": "astro preview",
    "check": "astro check && svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "rebuild:pdf-font": "node scripts/build-pdf-font.mjs",
    "download:cards": "node scripts/download-illustration-cards.mjs",
    "generate:cards": "node scripts/generate-placeholder-cards.mjs",
    "generate:icons": "node scripts/generate-pwa-icons.mjs",
    "generate:og": "node scripts/generate-og-image.mjs",
    "postbuild": "pagefind --site dist && node scripts/build-sw.mjs && node scripts/build-manifest.mjs && node scripts/verify-seo.mjs",
    "curate:videos": "tsx scripts/curate-videos.ts",
    "curate:clean": "tsx scripts/curate-videos.ts --clean"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/svelte": "^8.1.0",
    "@mediapipe/tasks-vision": "^0.10.35",
    "astro": "^6.3.1",
    "d3-array": "^3.2.4",
    "d3-axis": "^3.0.0",
    "d3-format": "^3.1.2",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-time": "^3.1.0",
    "d3-time-format": "^4.1.0",
    "dexie": "^4.4.2",
    "fhirclient": "^2.6.3",
    "js-yaml": "^4.1.1",
    "jspdf": "^4.2.1",
    "meyda": "^5.6.3",
    "onnxruntime-web": "^1.26.0",
    "pixi.js": "^8.18.1",
    "svelte": "^5.55.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@fontsource/noto-sans-tc": "^5.2.9",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@resvg/resvg-js": "^2.6.2",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-array": "^3.2.2",
    "@types/d3-axis": "^3.0.6",
    "@types/d3-format": "^3.0.4",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-shape": "^3.1.8",
    "@types/d3-time": "^3.0.4",
    "@types/d3-time-format": "^4.0.3",
    "@types/js-yaml": "^4.0.9",
    "@vitest/ui": "^4.1.6",
    "eslint": "^10.3.0",
    "fake-indexeddb": "^6.2.5",
    "fast-glob": "^3.3.3",
    "jsdom": "^29.1.1",
    "pagefind": "^1.5.2",
    "postcss": "^8.5.14",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "subset-font": "^2.5.0",
    "svelte-check": "^4.4.8",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "overrides": {
      "shell-quote": "^1.8.4",
      "devalue": "^5.8.1",
      "protobufjs": "^7.5.8",
      "postcss@8.4.49": "^8.5.10",
      "ws@8": "^8.20.1",
      "uuid@7": "^11.1.1",
      "uuid@8": "^11.1.1"
    }
  }
}
