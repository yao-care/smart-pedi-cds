---
import Base from './Base.astro';
import Header from '../components/blocks/Header.astro';
import Footer from '../components/blocks/Footer.astro';

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
}

const { title, description, noindex = false } = Astro.props;
---

<Base title={title} description={description} noindex={noindex}>
  <div class="app-layout">
    <Header />
    <main id="main-content" class="container" {...(noindex ? { 'data-pagefind-ignore': true } : { 'data-pagefind-body': true })}>
      <slot />
    </main>
    <Footer />
  </div>
</Base>

<style>
  .app-layout {
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
  }

  .app-layout main {
    flex: 1;
    padding: var(--space-6) 0;
  }
</style>
