---
import OfflineBanner from '../components/common/OfflineBanner.svelte';
import { BASE_PATH } from '../../scripts/base.mjs';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const canonicalURL = canonical
  ? new URL(canonical, Astro.site)
  : new URL(Astro.url.pathname, Astro.site);
const fullTitle = `${title} | CDSS 兒科臨床決策輔助系統`;
const base = BASE_PATH;

import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="zh-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="Content-Security-Policy" content="frame-src https://www.youtube-nocookie.com;" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="manifest" href={base + '/manifest.json'} />
    <link rel="apple-touch-icon" href={base + '/icons/icon-192.png'} />
    <meta name="theme-color" content="#c34a5e" />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:url" content={canonicalURL.href} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">跳至主要內容</a>
    <OfflineBanner client:idle />
    <slot />
    <script src="../lib/sw/register-entry.ts"></script>
  </body>
</html>
