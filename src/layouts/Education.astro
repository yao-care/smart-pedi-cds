---
import Base from './Base.astro';
import Header from '../components/blocks/Header.astro';
import Footer from '../components/blocks/Footer.astro';
import Breadcrumb from '../components/blocks/Breadcrumb.astro';

interface Props {
  title: string;
  description: string;
  breadcrumbs: { label: string; href?: string }[];
  /** Render the left sidebar column. Default false — most education pages
   *  (article detail, etc.) don't have sidebar content and need the main
   *  prose column to center in the container. */
  hasSidebar?: boolean;
}

const { title, description, breadcrumbs, hasSidebar = false } = Astro.props;
---

<Base title={title} description={description}>
  <div class="app-layout">
    <Header />
    <div class="container">
      <Breadcrumb items={breadcrumbs} />
      <div class:list={['edu-layout', { 'has-sidebar': hasSidebar }]}>
        {hasSidebar && (
          <aside class="edu-sidebar">
            <slot name="sidebar" />
          </aside>
        )}
        <main id="main-content" class="prose edu-main" data-pagefind-body>
          <slot />
        </main>
      </div>
    </div>
    <Footer />
  </div>
</Base>

<style>
  .app-layout {
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
  }

  .container {
    flex: 1;
    padding-top: var(--space-6);
    padding-bottom: var(--space-6);
  }

  .edu-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  /* Centre the prose column when there's no sidebar so content sits in the
     middle of the container instead of left-aligned with a wide right gutter. */
  .edu-layout:not(.has-sidebar) .edu-main {
    margin-left: auto;
    margin-right: auto;
  }

  @media (min-width: 768px) {
    .edu-layout.has-sidebar {
      grid-template-columns: 280px 1fr;
    }
  }
</style>
