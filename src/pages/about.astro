---
import App from '../layouts/App.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { organizationSchema } from '../lib/seo/schema';

const introHighlights = [
  '家長可自行操作的兒童發展篩檢',
  '隱私優先：資料不離開瀏覽器',
  '開源免費，免登入、免安裝',
  '六大發展面向，依年齡適性出題',
];

const flowSteps = [
  {
    title: '輸入年齡',
    desc: '以出生日期換算月齡。適用 0–72 個月，自動歸入 7 個年齡組（2–6m、7–12m、13–24m、25–36m、37–48m、49–60m、61–72m）。',
  },
  {
    title: '依年齡施測',
    desc: '按年齡組給對應的發展題目，引導家長完成各評估模組：問卷、互動遊戲、語音、繪圖、動作。',
  },
  {
    title: '與同齡常模比較',
    desc: '每個指標都換算成「比同齡平均落後或超前幾個標準差」（z 分數），再依面向合成綜合 z 分數。雷達圖上的 50 代表同齡第 50 百分位（即同齡平均），不是「答對一半」。',
    criteria: [
      '問卷面向：借用國際標準 ASQ-3 各年齡常模並依本系統題數縮放',
      '互動遊戲、繪圖、語音、動作：使用本平台對應模組的同齡基線',
      '統一以「相對同齡常模的標準差」呈現，跨面向可比較',
    ],
  },
  {
    title: '逐面向判讀（per-domain gating）',
    desc: '依國際多面向發展篩檢工具（ASQ-3／Bayley／Battelle／DAYC-2）共識，各面向以該面向的綜合 z 落點分類：',
    criteria: [
      '高於 −1 SD（同齡前 84% 以內）→ 正常',
      '落在 −1 ～ −2 SD（同齡第 2.5–16 百分位）→ 追蹤觀察',
      '低於 −2 SD（同齡後 2.5% 以下）→ 建議轉介',
    ],
  },
  {
    title: '綜合判讀（三級分流）',
    desc: '取各面向中最嚴重的分類作為整體分流（任一面向落到該級即升級）：',
  },
];

const outcomes = [
  { key: 'normal', tag: '正常', cond: '所有面向皆高於 −1 SD', action: '各面向發展在同齡正常範圍' },
  { key: 'monitor', tag: '追蹤觀察', cond: '任一面向落在 −1 ～ −2 SD', action: '建議持續觀察與居家促進' },
  { key: 'refer', tag: '建議轉介', cond: '任一面向低於 −2 SD', action: '建議進一步專業評估' },
];
---

<App title="關於" description="關於 Smart Pedi 兒童發展評估：免費、純瀏覽器、保護隱私的兒童發展篩檢自評工具。">
  <JsonLd data={organizationSchema(Astro.site!)} />

  <h1>關於 Smart Pedi 兒童發展評估</h1>

  <section class="about-section about-twocol" aria-label="系統介紹">
    <div class="twocol-main">
      <h2>系統介紹</h2>
      <p>
        Smart Pedi 是一套開源、免費的兒童發展篩檢自評工具。
        家長依孩子的年齡引導式作答，當下取得六大發展面向的風險分級與對應衛教建議。
        所有運算都在瀏覽器端完成，資料不離開裝置、不收集、不轉傳。
      </p>
    </div>
    <aside class="twocol-aside" aria-label="重點摘要">
      <h3>重點摘要</h3>
      <ul>
        {introHighlights.map((h) => <li>{h}</li>)}
      </ul>
    </aside>
  </section>

  <section class="about-section flow-section" aria-label="評估判讀流程">
    <h2>評估判讀流程</h2>
    <p class="flow-intro">
      從孩子的年齡開始，到產生衛教建議為止，系統的判讀邏輯如下。
      本流程僅為發展分流參考，不取代專業臨床判斷。
    </p>

    <ol class="flow">
      {flowSteps.map((step) => (
        <li class="flow-step">
          <h3>{step.title}</h3>
          <p>{step.desc}</p>
          {step.criteria && (
            <ul class="flow-criteria">
              {step.criteria.map((c) => <li>{c}</li>)}
            </ul>
          )}
        </li>
      ))}
    </ol>

    <div class="flow-branch" aria-hidden="true">↓</div>

    <div class="flow-outcomes" role="list" aria-label="三級分流結果">
      {outcomes.map((o) => (
        <div class={`outcome outcome-${o.key}`} role="listitem">
          <span class="outcome-tag">{o.tag}</span>
          <p class="outcome-cond">{o.cond}</p>
          <p class="outcome-action">{o.action}</p>
        </div>
      ))}
    </div>

    <div class="flow-branch" aria-hidden="true">↓</div>

    <div class="flow-edu">
      <h3>提供衛教資源</h3>
      <p>判讀為<strong>追蹤觀察</strong>或<strong>建議轉介</strong>時，依「分級 × 需注意面向」自動帶出：</p>
      <ul class="flow-criteria">
        <li><strong>建議閱讀</strong>：對應的衛教文章（內容可由各院所自訂）</li>
        <li><strong>參考影片</strong>：對應主題的精選衛教影片</li>
      </ul>
      <p class="flow-note">判讀為「正常」時，僅顯示結果摘要與發展雷達圖，不另行推送衛教資源。</p>
    </div>
  </section>

  <section class="about-section about-norms" aria-label="常模來源說明">
    <h2>常模來源說明</h2>
    <p>
      本系統採「常模參照」判讀（與 ASQ-3、Bayley、Battelle、DAYC-2 等國際多面向發展評估工具一致），
      每個面向都以「比同齡常模落後幾個標準差」為基準，而非「答對幾趴」。
      各模組的常模來源公開揭示如下：
    </p>
    <ul class="norms-list">
      <li>
        <strong>問卷六面向</strong>（粗動作、精細動作、語言理解、語言表達、認知、社會情緒）：
        借用 <a href="https://agesandstages.com/wp-content/uploads/2019/08/ASQ-3-Technical-Appendix_web.pdf" target="_blank" rel="noopener">ASQ-3 第三版 Technical Appendix Table 18</a>
        各年齡 mean / SD，依本系統題數做滿分縮放（mean<sub>本</sub> = mean<sub>ASQ-3</sub> × maxScore / 60）。
      </li>
      <li>
        <strong>語言理解 vs 語言表達</strong>：ASQ-3 將兩者合併為單一 Communication 面向，
        本系統暫共用同一組常模，未來累積在地資料後將分離校正（透明假設：兩 sub-domain 分佈相似）。
      </li>
      <li>
        <strong>61–72 月年齡組</strong>：ASQ-3 常模上限為 60m，本系統 61–72m 直接套用 60m 常模。
        此年齡的判讀僅供參考，建議搭配學齡前發展檢核。
      </li>
      <li>
        <strong>互動遊戲、繪圖、語音、動作</strong>：使用本平台模組設計時的內部參考常模（同齡基線），
        非外部標準化工具。本平台累積足夠資料後將以實際分佈校正。
      </li>
    </ul>
    <p class="norms-note">
      <strong>篩檢敏感性說明</strong>：本系統題目較 ASQ-3 精簡（每面向 1–2 題），統計上分數差 1 分相當於約 1.5–2 個標準差。
      為了維持「寧錯報不漏報」的篩檢精神，我們仍維持 −2 SD 嚴格門檻，因此假陽性會略高於 ASQ-3 全量表。
      若標示為「建議轉介」，請務必諮詢小兒科或兒童發展中心進行完整專業評估，本系統的篩檢結果不取代臨床診斷。
    </p>
  </section>

  <section class="about-cta" aria-label="開始評估">
    <a href="/assess/" class="cta-primary">開始評估</a>
  </section>
</App>

<style>
  h1 {
    margin-bottom: var(--space-6);
  }

  .about-section {
    margin-bottom: var(--space-8);
  }

  .about-section h2 {
    font-size: var(--text-2xl);
    line-height: var(--lh-2xl);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-4);
    color: var(--text);
  }

  .about-section p {
    font-size: var(--text-base);
    line-height: var(--lh-base);
    color: color-mix(in srgb, var(--text), var(--bg) 30%);
    max-width: 72ch;
  }

  /* ---------- 兩欄版面（系統介紹）---------- */
  .about-twocol {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 18rem);
    gap: var(--space-6);
    align-items: start;
  }

  .twocol-aside {
    background-color: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-5);
  }

  .twocol-aside h3 {
    font-size: var(--text-base);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-3);
    color: var(--text);
  }

  .twocol-aside ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .twocol-aside li {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: color-mix(in srgb, var(--text), var(--bg) 25%);
  }

  .twocol-aside li::before {
    content: '✓ ';
    color: var(--accent);
  }

  @media (max-width: 767px) {
    .about-twocol {
      grid-template-columns: 1fr;
    }
  }

  /* ---------- 評估判讀流程 ---------- */
  .flow-intro {
    max-width: 72ch;
  }

  .flow {
    list-style: none;
    margin: var(--space-5) 0 0;
    padding: 0;
    counter-reset: step;
  }

  .flow > li {
    position: relative;
    padding-left: calc(2.5rem + var(--space-4));
    padding-bottom: var(--space-5);
  }

  .flow > li::before {
    counter-increment: step;
    content: counter(step);
    position: absolute;
    left: 0;
    top: 0;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background-color: var(--accent);
    color: var(--bg);
    font-weight: var(--font-bold);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .flow > li:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 1.25rem;
    top: 2.5rem;
    bottom: 0;
    width: 2px;
    background-color: var(--line);
    transform: translateX(-1px);
  }

  .flow > li h3 {
    font-size: var(--text-lg);
    line-height: var(--lh-lg);
    font-weight: var(--font-bold);
    margin: 0 0 var(--space-2);
    color: var(--text);
  }

  .flow > li p {
    font-size: var(--text-base);
    line-height: var(--lh-base);
    color: color-mix(in srgb, var(--text), var(--bg) 25%);
    max-width: 72ch;
    margin: 0;
  }

  .flow-criteria {
    margin: var(--space-2) 0 0;
    padding-left: var(--space-5);
  }

  .flow-criteria li {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: color-mix(in srgb, var(--text), var(--bg) 25%);
    margin-bottom: var(--space-1);
  }

  .flow-branch {
    text-align: center;
    font-size: var(--text-2xl);
    line-height: 1;
    color: color-mix(in srgb, var(--text), var(--bg) 45%);
    margin: var(--space-2) 0;
  }

  .flow-outcomes {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-4);
  }

  .outcome {
    background-color: var(--surface);
    border: 1px solid var(--line);
    border-top: 4px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }

  .outcome p {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: color-mix(in srgb, var(--text), var(--bg) 20%);
    max-width: none;
    margin: 0 0 var(--space-1);
  }

  .outcome .outcome-action {
    font-weight: var(--font-medium);
    color: var(--text);
  }

  .outcome-tag {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--bg);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-2);
  }

  .outcome-normal {
    border-top-color: var(--accent);
    background-color: color-mix(in srgb, var(--accent) 10%, var(--bg));
  }
  .outcome-normal .outcome-tag {
    background-color: var(--accent);
  }

  .outcome-monitor {
    border-top-color: var(--warn);
    background-color: color-mix(in srgb, var(--warn) 10%, var(--bg));
  }
  .outcome-monitor .outcome-tag {
    background-color: var(--warn);
  }

  .outcome-refer {
    border-top-color: var(--danger);
    background-color: color-mix(in srgb, var(--danger) 12%, var(--bg));
  }
  .outcome-refer .outcome-tag {
    background-color: var(--danger);
  }

  .flow-edu {
    margin-top: var(--space-5);
    background-color: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-5);
  }

  .flow-edu h3 {
    font-size: var(--text-lg);
    line-height: var(--lh-lg);
    font-weight: var(--font-bold);
    margin: 0 0 var(--space-3);
    color: var(--text);
  }

  .flow-note {
    margin-top: var(--space-3);
    font-style: italic;
  }

  /* ---------- 常模來源說明 ---------- */
  .about-norms p {
    margin-bottom: var(--space-3);
  }

  .norms-list {
    list-style: disc;
    padding-left: var(--space-5);
    margin: 0 0 var(--space-4);
  }

  .norms-list li {
    font-size: var(--text-base);
    line-height: var(--lh-base);
    color: color-mix(in srgb, var(--text), var(--bg) 25%);
    margin-bottom: var(--space-3);
    max-width: 72ch;
  }

  .norms-list a {
    color: var(--accent);
    text-decoration: underline;
  }

  .norms-note {
    background-color: color-mix(in srgb, var(--warn) 8%, var(--bg));
    border-left: 4px solid var(--warn);
    border-radius: var(--radius-sm);
    padding: var(--space-4) var(--space-5);
    margin-top: var(--space-4);
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
  }

  .norms-note strong {
    color: var(--text);
  }

  /* ---------- 底部 CTA ---------- */
  .about-cta {
    text-align: center;
    padding: var(--space-6) 0;
    border-top: 1px solid var(--line);
  }

  .about-cta .cta-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    color: var(--bg);
    background-color: var(--accent);
    border-radius: var(--radius-md);
    text-decoration: none;
  }

  .about-cta .cta-primary:hover {
    background-color: color-mix(in srgb, var(--accent), black 12%);
  }
</style>
