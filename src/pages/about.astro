---
import App from '../layouts/App.astro';
import { siteFaqs, faqJsonLd } from '../data/site-faqs';

const introHighlights = [
  '雙角色：家長自評 + 醫護工作台',
  '隱私優先：資料不離開瀏覽器',
  '開源免費，免登入',
  'SMART on FHIR 標準',
];

const flowSteps = [
  {
    title: '輸入年齡',
    desc: '以出生日期換算月齡。適用 0–72 個月，自動歸入 7 個年齡組（2–6m、7–12m、13–24m、25–36m、37–48m、49–60m、61–72m）。',
  },
  {
    title: '依年齡施測',
    desc: '按年齡組給對應的發展題目，引導家長完成各評估模組：問卷、互動遊戲、語音、繪圖、動作。',
  },
  {
    title: '逐面向計分、標記「需注意」',
    desc: '六大發展面向（粗動作、精細動作、語言理解、語言表達、認知、社會情緒）各自評分，符合下列任一條件即標記為「需注意」：',
    criteria: [
      '問卷面向得分未達滿分的一半',
      '行為／繪圖／語音明顯偏離同齡常模（約 1.5 個標準差）',
      '動作經 AI 姿態分析判讀為疑似遲緩',
    ],
  },
  {
    title: '綜合判讀（三級分流）',
    desc: '同時看「需注意」的項目數，以及它們橫跨幾個發展面向，分為三級：',
  },
];

const outcomes = [
  { key: 'normal', tag: '正常', cond: '無「需注意」項目', action: '各面向發展在正常範圍' },
  { key: 'monitor', tag: '追蹤觀察', cond: '1 項以上「需注意」', action: '建議持續追蹤' },
  { key: 'refer', tag: '建議轉介', cond: '「需注意」≥ 3 項，且橫跨 ≥ 2 個面向', action: '建議進一步專業評估' },
];
---

<App title="關於" description="Smart Pedi 兒科健康評估與臨床決策輔助系統使用說明">
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <h1>關於 Smart Pedi 兒科健康輔助系統</h1>

  <section class="about-section about-twocol" aria-label="系統介紹">
    <div class="twocol-main">
      <h2>系統介紹</h2>
      <p>
        Smart Pedi 是一套開源的兒科健康輔助系統，提供雙角色服務：
        家長可透過 CDSA（臨床決策輔助應用）進行孩子健康自評並取得衛教建議；
        醫護人員可透過 CDSS（臨床決策輔助系統）工作台即時監測指標、接收預警。
        系統以 SMART on FHIR 標準運行於瀏覽器端，確保隱私與互通性。
      </p>
    </div>
    <aside class="twocol-aside" aria-label="重點摘要">
      <h3>重點摘要</h3>
      <ul>
        {introHighlights.map((h) => <li>{h}</li>)}
      </ul>
    </aside>
  </section>

  <section class="about-section flow-section" aria-label="臨床決策流程">
    <h2>臨床決策流程</h2>
    <p class="flow-intro">
      從孩子的年齡開始，到產生衛教建議為止，系統的判讀邏輯如下。
      本流程僅為發展分流參考，不取代專業臨床判斷。
    </p>

    <ol class="flow">
      {flowSteps.map((step) => (
        <li class="flow-step">
          <h3>{step.title}</h3>
          <p>{step.desc}</p>
          {step.criteria && (
            <ul class="flow-criteria">
              {step.criteria.map((c) => <li>{c}</li>)}
            </ul>
          )}
        </li>
      ))}
    </ol>

    <div class="flow-branch" aria-hidden="true">↓</div>

    <div class="flow-outcomes" role="list" aria-label="三級分流結果">
      {outcomes.map((o) => (
        <div class={`outcome outcome-${o.key}`} role="listitem">
          <span class="outcome-tag">{o.tag}</span>
          <p class="outcome-cond">{o.cond}</p>
          <p class="outcome-action">{o.action}</p>
        </div>
      ))}
    </div>

    <div class="flow-branch" aria-hidden="true">↓</div>

    <div class="flow-edu">
      <h3>提供衛教資源</h3>
      <p>判讀為<strong>追蹤觀察</strong>或<strong>建議轉介</strong>時，依「分級 × 需注意面向」自動帶出：</p>
      <ul class="flow-criteria">
        <li><strong>建議閱讀</strong>：對應的衛教文章（內容可由各院所自訂）</li>
        <li><strong>參考影片</strong>：對應主題的精選衛教影片</li>
      </ul>
      <p class="flow-note">判讀為「正常」時，僅顯示結果摘要與發展雷達圖，不另行推送衛教資源。</p>
    </div>
  </section>

  <section class="about-section" aria-label="常見問題">
    <h2>常見問題</h2>
    <div class="faq-list">
      {siteFaqs.map((faq) => (
        <details class="faq-item">
          <summary class="faq-question">{faq.question}</summary>
          <p class="faq-answer">{faq.answer}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="about-cta" aria-label="開始評估">
    <a href="/assess/" class="cta-primary">開始評估</a>
  </section>
</App>

<style>
  h1 {
    margin-bottom: var(--space-6);
  }

  .about-section {
    margin-bottom: var(--space-8);
  }

  .about-section h2 {
    font-size: var(--text-2xl);
    line-height: var(--lh-2xl);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-4);
    color: var(--text);
  }

  .about-section p {
    font-size: var(--text-base);
    line-height: var(--lh-base);
    color: color-mix(in srgb, var(--text), var(--bg) 30%);
    max-width: 72ch;
  }

  /* ---------- 兩欄版面（系統介紹）---------- */
  .about-twocol {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 18rem);
    gap: var(--space-6);
    align-items: start;
  }

  .twocol-aside {
    background-color: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-5);
  }

  .twocol-aside h3 {
    font-size: var(--text-base);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-3);
    color: var(--text);
  }

  .twocol-aside ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .twocol-aside li {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: color-mix(in srgb, var(--text), var(--bg) 25%);
  }

  .twocol-aside li::before {
    content: '✓ ';
    color: var(--accent);
  }

  @media (max-width: 767px) {
    .about-twocol {
      grid-template-columns: 1fr;
    }
  }

  /* ---------- 臨床決策流程 ---------- */
  .flow-intro {
    max-width: 72ch;
  }

  .flow {
    list-style: none;
    margin: var(--space-5) 0 0;
    padding: 0;
    counter-reset: step;
  }

  .flow > li {
    position: relative;
    padding-left: calc(2.5rem + var(--space-4));
    padding-bottom: var(--space-5);
  }

  .flow > li::before {
    counter-increment: step;
    content: counter(step);
    position: absolute;
    left: 0;
    top: 0;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background-color: var(--accent);
    color: var(--bg);
    font-weight: var(--font-bold);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .flow > li:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 1.25rem;
    top: 2.5rem;
    bottom: 0;
    width: 2px;
    background-color: var(--line);
    transform: translateX(-1px);
  }

  .flow > li h3 {
    font-size: var(--text-lg);
    line-height: var(--lh-lg);
    font-weight: var(--font-bold);
    margin: 0 0 var(--space-2);
    color: var(--text);
  }

  .flow > li p {
    font-size: var(--text-base);
    line-height: var(--lh-base);
    color: color-mix(in srgb, var(--text), var(--bg) 25%);
    max-width: 72ch;
    margin: 0;
  }

  .flow-criteria {
    margin: var(--space-2) 0 0;
    padding-left: var(--space-5);
  }

  .flow-criteria li {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: color-mix(in srgb, var(--text), var(--bg) 25%);
    margin-bottom: var(--space-1);
  }

  .flow-branch {
    text-align: center;
    font-size: var(--text-2xl);
    line-height: 1;
    color: color-mix(in srgb, var(--text), var(--bg) 45%);
    margin: var(--space-2) 0;
  }

  .flow-outcomes {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-4);
  }

  .outcome {
    background-color: var(--surface);
    border: 1px solid var(--line);
    border-top: 4px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }

  .outcome p {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: color-mix(in srgb, var(--text), var(--bg) 20%);
    max-width: none;
    margin: 0 0 var(--space-1);
  }

  .outcome .outcome-action {
    font-weight: var(--font-medium);
    color: var(--text);
  }

  .outcome-tag {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--bg);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-2);
  }

  .outcome-normal {
    border-top-color: var(--accent);
    background-color: color-mix(in srgb, var(--accent) 10%, var(--bg));
  }
  .outcome-normal .outcome-tag {
    background-color: var(--accent);
  }

  .outcome-monitor {
    border-top-color: var(--warn);
    background-color: color-mix(in srgb, var(--warn) 10%, var(--bg));
  }
  .outcome-monitor .outcome-tag {
    background-color: var(--warn);
  }

  .outcome-refer {
    border-top-color: var(--danger);
    background-color: color-mix(in srgb, var(--danger) 12%, var(--bg));
  }
  .outcome-refer .outcome-tag {
    background-color: var(--danger);
  }

  .flow-edu {
    margin-top: var(--space-5);
    background-color: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-5);
  }

  .flow-edu h3 {
    font-size: var(--text-lg);
    line-height: var(--lh-lg);
    font-weight: var(--font-bold);
    margin: 0 0 var(--space-3);
    color: var(--text);
  }

  .flow-note {
    margin-top: var(--space-3);
    font-style: italic;
  }

  /* ---------- FAQ ---------- */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .faq-item {
    background-color: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .faq-question {
    padding: var(--space-4) var(--space-5);
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    color: var(--text);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::after {
    content: '+';
    font-size: var(--text-xl);
    line-height: 1;
    color: color-mix(in srgb, var(--text), var(--bg) 45%);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .faq-item[open] .faq-question::after {
    content: '-';
  }

  .faq-answer {
    padding: 0 var(--space-5) var(--space-5);
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: color-mix(in srgb, var(--text), var(--bg) 30%);
    max-width: 72ch;
  }

  /* ---------- 底部 CTA ---------- */
  .about-cta {
    text-align: center;
    padding: var(--space-6) 0;
    border-top: 1px solid var(--line);
  }

  .about-cta .cta-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    color: var(--bg);
    background-color: var(--accent);
    border-radius: var(--radius-md);
    text-decoration: none;
  }

  .about-cta .cta-primary:hover {
    background-color: color-mix(in srgb, var(--accent), black 12%);
  }
</style>
