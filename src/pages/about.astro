---
import App from '../layouts/App.astro';
import { siteFaqs, faqJsonLd } from '../data/site-faqs';

const features = [
  { title: '家長自評 (CDSA)', description: '家長可透過引導式問卷評估孩子健康狀況，取得即時衛教建議' },
  { title: '臨床決策輔助 (CDSS)', description: '醫護人員可即時監測兒童健康指標，接收智慧預警與風險分級' },
  { title: '智慧預警引擎', description: '即時偵測兒童健康指標異常，自動分級預警' },
  { title: '衛教資源整合', description: '依評估結果與預警類型自動推播對應衛教內容' },
  { title: 'SMART on FHIR 整合', description: '可連線醫院 FHIR Server，或獨立離線使用' },
  { title: '完全離線運算', description: '所有邏輯在瀏覽器端執行，保護病患隱私' },
];

const introHighlights = [
  '雙角色：家長自評 + 醫護工作台',
  '隱私優先：資料不離開瀏覽器',
  '開源免費，免登入',
  'SMART on FHIR 標準',
];

const techStack = ['Astro 5', 'Svelte 5', 'Web Worker', 'GitHub Pages', '零後端'];
---

<App title="關於" description="Smart Pedi 兒科健康評估與臨床決策輔助系統使用說明">
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <h1>關於 Smart Pedi 兒科健康輔助系統</h1>

  <section class="about-section about-twocol" aria-label="系統介紹">
    <div class="twocol-main">
      <h2>系統介紹</h2>
      <p>
        Smart Pedi 是一套開源的兒科健康輔助系統，提供雙角色服務：
        家長可透過 CDSA（臨床決策輔助應用）進行孩子健康自評並取得衛教建議；
        醫護人員可透過 CDSS（臨床決策輔助系統）工作台即時監測指標、接收預警。
        系統以 SMART on FHIR 標準運行於瀏覽器端，確保隱私與互通性。
      </p>
    </div>
    <aside class="twocol-aside" aria-label="重點摘要">
      <h3>重點摘要</h3>
      <ul>
        {introHighlights.map((h) => <li>{h}</li>)}
      </ul>
    </aside>
  </section>

  <section class="about-section" aria-label="功能概覽">
    <h2>功能概覽</h2>
    <div class="feature-list">
      {features.map((feature) => (
        <div class="feature-item">
          <h3>{feature.title}</h3>
          <p>{feature.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="about-section about-twocol" aria-label="技術架構">
    <div class="twocol-main">
      <h2>技術架構簡述</h2>
      <p>
        本系統採用 Astro 5 靜態網站生成框架，搭配 Svelte 5 做為互動元件的島嶼架構。
        前端以 SMART on FHIR 標準與醫院 FHIR Server 通訊，所有臨床決策邏輯
        （規則引擎、趨勢分析、風險評估）皆在瀏覽器端以 Web Worker 執行，
        確保效能與隱私兼顧。靜態資產部署於 GitHub Pages，無需後端伺服器。
      </p>
    </div>
    <aside class="twocol-aside" aria-label="技術棧">
      <h3>技術棧</h3>
      <ul class="tech-badges">
        {techStack.map((t) => <li>{t}</li>)}
      </ul>
    </aside>
  </section>

  <section class="about-section" aria-label="使用方式">
    <h2>使用方式</h2>
    <div class="usage-modes">
      <div class="usage-card">
        <h3>家長評估 (CDSA)</h3>
        <p>
          從首頁選擇「我是家長」進入評估流程。透過引導式問卷回答孩子的健康狀況，
          系統將即時提供衛教建議。可選擇性連線醫院 FHIR Server，
          將評估結果傳送至醫療團隊。
        </p>
      </div>
      <div class="usage-card">
        <h3>醫師工作台 (CDSS)</h3>
        <p>
          從首頁選擇「我是醫師」進入臨床工作台。工作台提供儀表板、預警管理、
          個案檢視等功能，可透過 SMART on FHIR 連線醫院 EHR 系統，
          或以 Standalone 模式獨立使用。
        </p>
      </div>
    </div>
  </section>

  <section class="about-section" aria-label="常見問題">
    <h2>常見問題</h2>
    <div class="faq-list">
      {siteFaqs.map((faq) => (
        <details class="faq-item">
          <summary class="faq-question">{faq.question}</summary>
          <p class="faq-answer">{faq.answer}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="about-cta" aria-label="開始評估">
    <a href="/assess" class="cta-primary">開始評估</a>
  </section>
</App>

<style>
  h1 {
    margin-bottom: var(--space-6);
  }

  .about-section {
    margin-bottom: var(--space-8);
  }

  .about-section h2 {
    font-size: var(--text-2xl);
    line-height: var(--lh-2xl);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-4);
    color: var(--text);
  }

  .about-section p {
    font-size: var(--text-base);
    line-height: var(--lh-base);
    color: color-mix(in srgb, var(--text), var(--bg) 30%);
    max-width: 72ch;
  }

  /* ---------- 兩欄版面 ---------- */
  .about-twocol {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 18rem);
    gap: var(--space-6);
    align-items: start;
  }

  .twocol-aside {
    background-color: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-5);
  }

  .twocol-aside h3 {
    font-size: var(--text-base);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-3);
    color: var(--text);
  }

  .twocol-aside ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .twocol-aside li {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: color-mix(in srgb, var(--text), var(--bg) 25%);
  }

  .twocol-aside li::before {
    content: '✓ ';
    color: var(--accent);
  }

  .twocol-aside .tech-badges {
    flex-direction: row;
    flex-wrap: wrap;
  }

  .tech-badges li {
    background-color: color-mix(in srgb, var(--bg), var(--text) 6%);
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-3);
  }

  .tech-badges li::before {
    content: none;
  }

  @media (max-width: 767px) {
    .about-twocol {
      grid-template-columns: 1fr;
    }
  }

  /* ---------- 底部 CTA ---------- */
  .about-cta {
    text-align: center;
    padding: var(--space-6) 0;
    border-top: 1px solid var(--line);
  }

  .about-cta .cta-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    color: var(--bg);
    background-color: var(--accent);
    border-radius: var(--radius-md);
    text-decoration: none;
  }

  .about-cta .cta-primary:hover {
    background-color: color-mix(in srgb, var(--accent), #000 12%);
  }

  /* ---------- Feature list ---------- */
  .feature-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-5);
  }

  .feature-item {
    background-color: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-5);
  }

  .feature-item h3 {
    font-size: var(--text-lg);
    line-height: var(--lh-lg);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-2);
    color: var(--text);
  }

  .feature-item p {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: color-mix(in srgb, var(--text), var(--bg) 30%);
  }

  /* ---------- Usage modes ---------- */
  .usage-modes {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-6);
  }

  .usage-card {
    background-color: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .usage-card h3 {
    font-size: var(--text-lg);
    line-height: var(--lh-lg);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-3);
    color: var(--accent);
  }

  .usage-card p {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
  }

  /* ---------- FAQ ---------- */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .faq-item {
    background-color: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .faq-question {
    padding: var(--space-4) var(--space-5);
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    color: var(--text);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::after {
    content: '+';
    font-size: var(--text-xl);
    line-height: 1;
    color: color-mix(in srgb, var(--text), var(--bg) 45%);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .faq-item[open] .faq-question::after {
    content: '-';
  }

  .faq-answer {
    padding: 0 var(--space-5) var(--space-5);
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: color-mix(in srgb, var(--text), var(--bg) 30%);
    max-width: 72ch;
  }
</style>
