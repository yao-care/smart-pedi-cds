---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const cards = await getCollection('cards');
const approved = cards.filter((c) => c.data.reviewStatus === 'approved');
const bySource = new Map<string, typeof approved>();
for (const c of approved) {
  const key = c.data.source;
  const list = bySource.get(key) ?? [];
  list.push(c);
  bySource.set(key, list);
}
---

<Base title="圖卡來源與授權" description="遊戲圖卡的來源、攝影／插畫者與授權聲明">
  <main class="page">
    <h1>圖卡來源與授權</h1>
    <p class="intro">本系統評估遊戲所使用的圖卡，授權與創作者資訊如下。</p>

    {approved.length === 0 && (
      <p class="empty">目前尚無已審核通過的圖卡。圖卡庫建置中。</p>
    )}

    {Array.from(bySource.entries()).map(([source, list]) => (
      <section class="source-group">
        <h2>{source}</h2>
        <ul class="credit-list">
          {list.map((card) => (
            <li>
              <strong>{card.id}</strong> ·
              {card.data.attribution ? ` ${card.data.attribution}` : ' （未署名）'}
              · <a href={card.data.sourceUrl} target="_blank" rel="noopener noreferrer">來源</a>
              · {card.data.license}
            </li>
          ))}
        </ul>
      </section>
    ))}

    <section class="general">
      <h2>整體授權聲明</h2>
      <ul>
        <li><strong>Pexels</strong> — 免費商用，<a href="https://www.pexels.com/license/" target="_blank" rel="noopener noreferrer">Pexels License</a></li>
        <li><strong>CC0</strong> — Public Domain（無需署名）</li>
        <li><strong>CC-BY</strong> — 需署名創作者</li>
        <li><strong>MIT</strong> — MIT License</li>
      </ul>
    </section>
  </main>
</Base>

<style>
  .page {
    max-width: 720px;
    margin: 0 auto;
    padding: var(--space-6) var(--space-4);
  }

  h1 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-2);
  }

  .intro {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-bottom: var(--space-6);
  }

  .empty {
    color: var(--color-text-muted);
    padding: var(--space-6);
    text-align: center;
    background: var(--bg-muted);
    border-radius: var(--radius-md);
  }

  .source-group {
    margin-top: var(--space-6);
  }

  .source-group h2 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-3);
  }

  .credit-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .credit-list li {
    font-size: var(--text-xs);
    color: var(--text);
    padding: var(--space-2) var(--space-3);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
  }

  .credit-list a {
    color: var(--accent);
    text-decoration: none;
  }

  .credit-list a:hover {
    text-decoration: underline;
  }

  .general {
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--line);
  }

  .general h2 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-3);
  }
</style>
