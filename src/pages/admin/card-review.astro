---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const cards = await getCollection('cards');
const sorted = [...cards].sort((a, b) => {
  if (a.data.domain !== b.data.domain) return a.data.domain.localeCompare(b.data.domain);
  return a.id.localeCompare(b.id);
});

const counts = {
  total: cards.length,
  pending: cards.filter((c) => c.data.reviewStatus === 'pending').length,
  approved: cards.filter((c) => c.data.reviewStatus === 'approved').length,
  rejected: cards.filter((c) => c.data.reviewStatus === 'rejected').length,
};

const domainLabels: Record<string, string> = {
  gross_motor: '粗動作',
  fine_motor: '精細動作',
  language_comp: '語言理解',
  language_expr: '語言表達',
  cognition: '認知',
  social_emotional: '社會情緒',
  behavior: '生活行為',
  diet: '飲食',
};

const presentDomains = Array.from(new Set(sorted.map((c) => c.data.domain))).sort();
---

<Base title="圖卡審核" description="人工檢視所有圖卡，編輯 src/data/cards/index.json 修改 reviewStatus">
  <main class="page">
    <h1>圖卡審核（唯讀檢視）</h1>
    <p class="intro">
      實際變更狀態請直接編輯 <code>src/data/cards/index.json</code> 並 commit。
      審核要點：(a) 不含可辨識真人臉部 (b) 兒童安全（普遍級） (c) 主體清晰。
    </p>

    <div class="stats">
      <span>總數 <strong>{counts.total}</strong></span>
      <span class="stat-pending">待審 <strong>{counts.pending}</strong></span>
      <span class="stat-approved">通過 <strong>{counts.approved}</strong></span>
      <span class="stat-rejected">退回 <strong>{counts.rejected}</strong></span>
    </div>

    <div class="filters" role="toolbar" aria-label="圖卡篩選">
      <div class="filter-row">
        <span class="filter-label">狀態</span>
        <div class="chips">
          <button type="button" class="chip active" data-status-filter="all">全部</button>
          <button type="button" class="chip" data-status-filter="pending">待審</button>
          <button type="button" class="chip" data-status-filter="approved">通過</button>
          <button type="button" class="chip" data-status-filter="rejected">退回</button>
        </div>
      </div>
      <div class="filter-row">
        <span class="filter-label">領域</span>
        <div class="chips">
          <button type="button" class="chip active" data-domain-filter="all">全部</button>
          {presentDomains.map((domain) => (
            <button type="button" class="chip" data-domain-filter={domain}>
              {domainLabels[domain] ?? domain}
            </button>
          ))}
        </div>
      </div>
      <p class="empty-msg" hidden>無符合條件的圖卡。</p>
    </div>

    <div class="card-grid">
      {sorted.map((card) => (
        <article
          class={`card card-${card.data.reviewStatus}`}
          data-card
          data-status={card.data.reviewStatus}
          data-domain={card.data.domain}
        >
          <div class="thumb">
            <img src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/cards/${card.data.filename}`}
                 alt={card.data.description}
                 loading="lazy"
                 width="200" height="200" />
          </div>
          <div class="meta">
            <span class={`status status-${card.data.reviewStatus}`}>{card.data.reviewStatus}</span>
            <strong class="title">{card.data.description}</strong>
            <span class="id-line">{card.id} · {domainLabels[card.data.domain] ?? card.data.domain}</span>
            {card.data.attribution && <p class="attr">{card.data.attribution}</p>}
            <span class="license">授權：{card.data.license}</span>
          </div>
        </article>
      ))}
    </div>
  </main>
</Base>

<script>
  // Plain DOM filtering on the SSG grid: no fetch, no rerender.
  const statusButtons = document.querySelectorAll<HTMLButtonElement>('[data-status-filter]');
  const domainButtons = document.querySelectorAll<HTMLButtonElement>('[data-domain-filter]');
  const cards = document.querySelectorAll<HTMLElement>('[data-card]');
  const emptyMsg = document.querySelector<HTMLElement>('.empty-msg');

  let activeStatus = 'all';
  let activeDomain = 'all';

  function applyFilter() {
    let visible = 0;
    cards.forEach((card) => {
      const matchStatus = activeStatus === 'all' || card.dataset.status === activeStatus;
      const matchDomain = activeDomain === 'all' || card.dataset.domain === activeDomain;
      const show = matchStatus && matchDomain;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (emptyMsg) emptyMsg.hidden = visible > 0;
  }

  statusButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeStatus = btn.dataset.statusFilter ?? 'all';
      statusButtons.forEach((b) => b.classList.toggle('active', b === btn));
      applyFilter();
    });
  });

  domainButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeDomain = btn.dataset.domainFilter ?? 'all';
      domainButtons.forEach((b) => b.classList.toggle('active', b === btn));
      applyFilter();
    });
  });
</script>

<style>
  .page {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-6) var(--space-4);
  }

  h1 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-2);
  }

  .intro {
    color: color-mix(in srgb, var(--text), var(--bg) 30%);
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
  }

  code {
    background: color-mix(in srgb, var(--bg), var(--text) 5%);
    padding: 0 0.25em;
    border-radius: 4px;
  }

  .stats {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-4);
    font-size: var(--text-sm);
  }

  .stat-pending strong { color: var(--warn); }
  .stat-approved strong { color: var(--accent); }
  .stat-rejected strong { color: var(--danger); }

  .filters {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
    padding: var(--space-3) var(--space-4);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
  }

  .filter-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .filter-label {
    font-size: var(--text-xs);
    color: color-mix(in srgb, var(--text), var(--bg) 30%);
    min-width: 36px;
  }

  .chips {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .chip {
    border: 1px solid var(--line);
    background: var(--bg);
    padding: 4px 12px;
    min-height: 32px;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    cursor: pointer;
    color: color-mix(in srgb, var(--text), var(--bg) 30%);
  }

  .chip.active {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }

  .chip:hover:not(.active) {
    border-color: var(--accent);
    color: var(--accent);
  }

  .empty-msg {
    margin: var(--space-2) 0 0;
    color: color-mix(in srgb, var(--text), var(--bg) 30%);
    font-size: var(--text-xs);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-4);
  }

  .card {
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--surface);
  }

  .card-approved { border-color: var(--accent); }
  .card-rejected { opacity: 0.5; }

  .thumb img {
    width: 100%;
    height: auto;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
  }

  .meta {
    padding: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-size: var(--text-xs);
  }

  .status {
    display: inline-block;
    padding: 2px 6px;
    border-radius: 4px;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.65rem;
    align-self: flex-start;
  }

  .status-pending { background: var(--color-risk-advisory-bg); color: var(--warn); }
  .status-approved { background: var(--color-risk-normal-bg); color: var(--accent); }
  .status-rejected { background: var(--color-risk-critical-bg); color: var(--danger); }

  .title { color: var(--text); }
  .id-line { color: color-mix(in srgb, var(--text), var(--bg) 30%); font-size: 0.7rem; }
  .attr { color: color-mix(in srgb, var(--text), var(--bg) 45%); font-size: 0.7rem; margin: 0; }
  .license { color: color-mix(in srgb, var(--text), var(--bg) 45%); font-size: 0.7rem; }
</style>
