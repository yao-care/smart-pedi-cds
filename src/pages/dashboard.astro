---
import App from '../layouts/App.astro';
import RiskSummary from '../components/dashboard/RiskSummary.svelte';
import PatientList from '../components/dashboard/PatientList.svelte';
import AlertFeed from '../components/dashboard/AlertFeed.svelte';
---

<App title="臨床儀表板" description="兒童健康監測與預警總覽">
  <h1>臨床儀表板</h1>

  <div class="dashboard-grid">
    <section class="risk-summary-section" aria-label="風險摘要">
      <h2>風險摘要</h2>
      <RiskSummary client:load />
    </section>

    <section class="patient-list-section" aria-label="病患列表">
      <h2>病患列表</h2>
      <PatientList client:load />
    </section>

    <section class="alert-feed-section" aria-label="即時預警">
      <h2>即時預警</h2>
      <AlertFeed client:visible />
    </section>
  </div>
</App>

<style>
  h1 {
    margin-bottom: var(--space-6);
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .dashboard-grid {
      grid-template-columns: 1fr 1fr;
    }

    .patient-list-section {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 1024px) {
    .dashboard-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }

    .patient-list-section {
      grid-column: auto;
    }
  }

  section {
    background-color: var(--bg-surface);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  section h2 {
    font-size: var(--text-lg);
    line-height: var(--lh-lg);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-4);
    color: var(--color-text-base);
  }
</style>
