---
import Education from '../../layouts/Education.astro';
import { getCollection, render } from 'astro:content';
import InteractionTracker from '../../components/education/InteractionTracker.svelte';
import EducationRelatedVideos from '../../components/education/EducationRelatedVideos.svelte';
import JsonLd from '../../components/seo/JsonLd.astro';
import { medicalWebPageSchema } from '../../lib/seo/schema';
import { MATRIX_ARTICLE_SLUGS } from '../../lib/education/core-articles';

export async function getStaticPaths() {
  const entries = await getCollection('education');
  const matrixSet = new Set(MATRIX_ARTICLE_SLUGS);
  // 只產生「矩陣對應文章」與「里程碑」頁；排除無對外入口的孤兒食譜（nutrition-*），
  // 使其不存在於 dist → 不進 sitemap、不被 Pagefind 索引、頁面 source 無食譜全文
  return entries
    .filter((entry) => matrixSet.has(entry.id) || entry.data.category === 'milestone')
    .map((entry) => ({
      params: { slug: entry.id },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const categoryLabels: Record<string, string> = {
  diet: '飲食',
  sleep: '睡眠',
  respiratory: '呼吸',
  exercise: '運動',
  milestone: '發展里程碑',
  general: '一般',
};

const ageGroupLabels: Record<string, string> = {
  infant: '嬰兒',
  toddler: '幼兒',
  preschool: '學齡前',
};

const formatLabels: Record<string, string> = {
  article: '文章',
  video: '影片',
  questionnaire: '問卷',
};

const breadcrumbs = [
  { label: '首頁', href: '/' },
  { label: '衛教內容', href: '/education/' },
  { label: entry.data.title },
];

const medicalSchema = medicalWebPageSchema(Astro.site!, {
  title: entry.data.title,
  summary: entry.data.summary,
  ageGroups: entry.data.ageGroup,
  url: new URL(`/education/${entry.id}/`, Astro.site!).href,
  publishedAt: entry.data.publishedAt,
  updatedAt: entry.data.updatedAt,
});
---

<Education
  title={entry.data.title}
  description={entry.data.summary}
  breadcrumbs={breadcrumbs}
>
  <JsonLd data={medicalSchema} />
  <h1>{entry.data.title}</h1>

  <div class="content-meta">
    <span class="meta-badge category-badge">{categoryLabels[entry.data.category] ?? entry.data.category}</span>
    <span class="meta-badge format-badge">{formatLabels[entry.data.format] ?? entry.data.format}</span>
    {entry.data.ageGroup.map((age: string) => (
      <span class="meta-badge age-badge">{ageGroupLabels[age] ?? age}</span>
    ))}
  </div>

  {entry.data.format === 'article' && <Content />}

  <!-- Interaction tracking (background, no visible UI) -->
  <InteractionTracker client:idle contentSlug={entry.id} />

  <!-- Related education videos derived from trigger mappings -->
  <EducationRelatedVideos client:visible slug={entry.id} />
</Education>

<style>
  .content-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .meta-badge {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    border-radius: var(--radius-full);
  }

  .category-badge {
    color: color-mix(in srgb, var(--accent) 85%, black);
    background-color: color-mix(in srgb, var(--accent) 10%, var(--bg));
  }

  .format-badge {
    color: var(--accent);
    background-color: color-mix(in srgb, var(--accent) 12%, var(--bg));
  }

  .age-badge {
    color: color-mix(in srgb, var(--text), var(--bg) 30%);
    background-color: color-mix(in srgb, var(--bg), var(--text) 5%);
  }
</style>
