---
import App from '../../layouts/App.astro';
import { getCollection } from 'astro:content';
import CustomEducationList from '../../components/education/CustomEducationList.svelte';

const allEducation = await getCollection('education');

const categoryLabels: Record<string, string> = {
  diet: '飲食',
  sleep: '睡眠',
  respiratory: '呼吸',
  exercise: '運動',
  milestone: '發展里程碑',
  general: '一般',
};

const ageGroupLabels: Record<string, string> = {
  infant: '嬰兒',
  toddler: '幼兒',
  preschool: '學齡前',
};
---

<App title="衛教內容" description="兒科健康衛教資源">
  <h1>衛教內容</h1>

  <div id="search" class="search-container">
    <!-- Pagefind search UI placeholder -->
  </div>

  <div class="education-grid">
    {allEducation.map((entry) => (
      <article class="education-card">
        <a href={`/smart-pedi-cds/education/${entry.id}/`} class="card-link">
          <span class="card-badge">{categoryLabels[entry.data.category] ?? entry.data.category}</span>
          <h2 class="card-title">{entry.data.title}</h2>
          <p class="card-summary">{entry.data.summary}</p>
          <div class="card-tags">
            {entry.data.ageGroup.map((age: string) => (
              <span class="tag">{ageGroupLabels[age] ?? age}</span>
            ))}
          </div>
        </a>
      </article>
    ))}
  </div>

  <CustomEducationList client:idle />
</App>

<style>
  h1 {
    margin-bottom: var(--space-6);
  }

  .search-container {
    margin-bottom: var(--space-6);
  }

  .education-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-6);
  }

  .education-card {
    background-color: var(--bg-surface);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color 0.2s ease;
  }

  .education-card:hover {
    border-color: var(--color-accent);
  }

  .card-link {
    display: block;
    padding: var(--space-6);
    text-decoration: none;
    color: inherit;
  }

  .card-badge {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    color: var(--color-accent);
    background-color: var(--color-risk-advisory-bg);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-3);
  }

  .card-title {
    font-size: var(--text-lg);
    line-height: var(--lh-lg);
    font-weight: var(--font-bold);
    color: var(--color-text-base);
    margin-bottom: var(--space-3);
  }

  .card-summary {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .card-tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .tag {
    display: inline-block;
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    background-color: var(--bg-muted);
    border-radius: var(--radius-sm);
  }
</style>
