---
import Base from '../layouts/Base.astro';
import Header from '../components/blocks/Header.astro';
import AssessmentHistory from '../components/assess/AssessmentHistory.svelte';
---

<Base title="評估紀錄" description="過去的兒童發展評估紀錄" noindex>
  <div class="history-layout">
    <Header />
    <main id="main-content" class="history-main" data-pagefind-ignore>
      <AssessmentHistory client:load />
    </main>
  </div>
</Base>

<style>
  .history-layout {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  .history-main {
    flex: 1;
    padding: var(--space-6) var(--space-4);
    max-width: 960px;
    width: 100%;
    margin: 0 auto;
  }
</style>
