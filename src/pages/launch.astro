---
import App from '../layouts/App.astro';
import LaunchSelector from '../components/fhir/LaunchSelector.svelte';
---

<App title="SMART on FHIR 連線" description="連線至醫院 FHIR Server">
  <h1>SMART on FHIR 連線</h1>
  <p>選擇啟動模式以連線至您的 FHIR Server。</p>
  <div class="launch-container">
    <LaunchSelector client:load />
  </div>
</App>

<style>
  h1 {
    margin-bottom: var(--space-4);
  }

  p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .launch-container {
    background-color: var(--bg-surface);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    min-height: 320px;
  }
</style>
