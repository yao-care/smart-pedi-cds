---
import App from '../layouts/App.astro';
---

<App title="個案檢視" description="兒童健康指標趨勢與預警歷史">
  <h1>個案檢視</h1>
  <p class="text-muted">病患資料將依據 URL 參數載入。</p>

  <div class="patient-grid">
    <section class="trend-charts" aria-label="指標趨勢圖">
      <h2>指標趨勢圖</h2>
      <!-- TrendChart.svelte will mount here -->
      <div class="placeholder">Svelte 元件載入中…</div>
    </section>

    <section class="alert-timeline" aria-label="預警時間軸">
      <h2>預警時間軸</h2>
      <!-- AlertTimeline.svelte will mount here -->
      <div class="placeholder">Svelte 元件載入中…</div>
    </section>

    <section class="baseline-info" aria-label="基線資訊">
      <h2>基線資訊</h2>
      <!-- BaselineCard.svelte will mount here -->
      <div class="placeholder">Svelte 元件載入中…</div>
    </section>
  </div>
</App>

<style>
  h1 {
    margin-bottom: var(--space-3);
  }

  .text-muted {
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .patient-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .patient-grid {
      grid-template-columns: 1fr 1fr;
    }

    .trend-charts {
      grid-column: 1 / -1;
    }
  }

  section {
    background-color: var(--bg-surface);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  section h2 {
    font-size: var(--text-lg);
    line-height: var(--lh-lg);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-4);
    color: var(--color-text-base);
  }

  .placeholder {
    padding: var(--space-8);
    text-align: center;
    color: var(--color-text-subtle);
    font-size: var(--text-sm);
    border: 1px dashed var(--border-default);
    border-radius: var(--radius-md);
  }
</style>
