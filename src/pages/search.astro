---
import App from '../layouts/App.astro';
import { BASE_PATH } from '../../scripts/base.mjs';
const base = BASE_PATH;
---

<App title="站內搜尋" description="搜尋兒童發展衛教內容。" noindex>
  <h1>站內搜尋</h1>
  <div id="search"></div>

  <link rel="stylesheet" href={`${base}/pagefind/pagefind-ui.css`} />
  <script is:inline src={`${base}/pagefind/pagefind-ui.js`}></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      // PagefindUI 於 build 後的 /pagefind/ 提供；dev 模式無索引屬正常。
      if (typeof window.PagefindUI !== 'function') return;
      new window.PagefindUI({ element: '#search', showSubResults: true });
      const q = new URLSearchParams(location.search).get('q');
      if (q) {
        const input = document.querySelector('#search input[type="text"]');
        if (input) {
          input.value = q;
          input.dispatchEvent(new Event('input', { bubbles: true }));
        }
      }
    });
  </script>
</App>

<style>
  #search {
    margin-top: var(--space-5);
  }
</style>
